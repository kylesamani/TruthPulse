{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "truthpulse",
  "title": "TruthPulse — Kalshi Markets",
  "description": "Instant Kalshi prediction market search with live odds and trends",
  "icon": "icon.png",
  "author": "kyle_samani",
  "categories": ["Finance"],
  "license": "MIT",
  "commands": [
    {
      "name": "search-markets",
      "title": "Search Kalshi Markets",
      "subtitle": "TruthPulse",
      "description": "Search Kalshi prediction markets with live odds",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.83.0",
    "@raycast/utils": "^1.17.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "22.10.2",
    "@types/react": "^19.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  },
  "scripts": {
    "build": "ray build -e dist -o dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "prepublishOnly": "echo \"Error: no publish\" && exit 1",
    "publish": "npx @raycast/api@latest publish"
  }
}
