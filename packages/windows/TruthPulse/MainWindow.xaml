<Window
    x:Class="TruthPulse.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="TruthPulse"
    Width="520"
    Height="580"
    WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="SegmentButton" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="#EEEEEE" CornerRadius="6"
                                Padding="10,5" Cursor="Hand">
                            <TextBlock x:Name="Txt" Text="{TemplateBinding Content}"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="#666666" HorizontalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#10B981" />
                                <Setter TargetName="Txt" Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#D1FAE5" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsChecked" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#059669" />
                                <Setter TargetName="Txt" Property="Foreground" Value="White" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F0FFF8" Offset="0.0" />
                <GradientStop Color="#FFFFFF" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="20,16,20,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="TruthPulse" FontSize="18" FontWeight="Bold"
                           Foreground="#1A1A1A" />
                <TextBlock Text=".co" FontSize="18"
                           Foreground="#10B981" Margin="0,0,12,0" />
                <TextBlock Text="powered by Kalshi" FontSize="11"
                           Foreground="#999999" VerticalAlignment="Center"
                           Margin="0,2,0,0" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <RadioButton x:Name="Window1D" Content="1D" GroupName="TrendWindow"
                             Click="WindowRadio_Click" Style="{StaticResource SegmentButton}"
                             Margin="0,0,2,0" />
                <RadioButton x:Name="Window7D" Content="7D" GroupName="TrendWindow"
                             Click="WindowRadio_Click" Style="{StaticResource SegmentButton}"
                             IsChecked="True" Margin="0,0,2,0" />
                <RadioButton x:Name="Window30D" Content="30D" GroupName="TrendWindow"
                             Click="WindowRadio_Click" Style="{StaticResource SegmentButton}" />
            </StackPanel>
        </Grid>

        <!-- Search input -->
        <Grid Grid.Row="1" Margin="20,4,20,12">
            <TextBox x:Name="SearchBox"
                     FontSize="15"
                     Padding="12,10"
                     TextChanged="SearchBox_TextChanged"
                     PreviewKeyDown="SearchBox_KeyDown" />
            <TextBlock x:Name="SearchPlaceholder"
                       Text="Search all Kalshi markets."
                       FontSize="15"
                       Foreground="#999999"
                       Margin="14,10,0,0"
                       IsHitTestVisible="False"
                       Visibility="Visible" />
        </Grid>

        <!-- Results list -->
        <ListBox x:Name="ResultsListBox" Grid.Row="2"
                 Margin="8,0,8,0"
                 SelectionChanged="ResultsListBox_SelectionChanged"
                 MouseDoubleClick="ResultsListBox_MouseDoubleClick"
                 BorderThickness="0"
                 Background="Transparent"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled" />

        <!-- Status bar -->
        <Grid Grid.Row="3" Margin="20,8,20,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="SyncStatusText" Grid.Column="0"
                       FontSize="11" Foreground="#999999"
                       VerticalAlignment="Center" />
            <TextBlock x:Name="ResultCountText" Grid.Column="1"
                       FontSize="11" Foreground="#999999"
                       VerticalAlignment="Center" />
        </Grid>
    </Grid>
</Window>
