<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0-windows10.0.22621.0</TargetFramework>
    <UseWPF>true</UseWPF>
    <Platforms>x64;ARM64</Platforms>
    <PlatformTarget>$(Platform)</PlatformTarget>
    <RootNamespace>Community.PowerToys.Run.Plugin.TruthPulse</RootNamespace>
    <AssemblyName>Community.PowerToys.Run.Plugin.TruthPulse</AssemblyName>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
  </PropertyGroup>

  <!-- Reference PowerToys DLLs from installation directory -->
  <PropertyGroup>
    <PowerToysDir>C:\Program Files\PowerToys\modules\launcher</PowerToysDir>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="Wox.Plugin">
      <HintPath>$(PowerToysDir)\Wox.Plugin.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Wox.Infrastructure">
      <HintPath>$(PowerToysDir)\Wox.Infrastructure.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="PowerToys.ManagedCommon">
      <HintPath>$(PowerToysDir)\PowerToys.ManagedCommon.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <None Update="plugin.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Images\*.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
