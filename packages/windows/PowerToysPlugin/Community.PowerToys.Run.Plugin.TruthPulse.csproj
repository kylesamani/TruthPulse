<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0-windows10.0.22621.0</TargetFramework>
    <UseWPF>true</UseWPF>
    <Platforms>x64;ARM64</Platforms>
    <PlatformTarget>$(Platform)</PlatformTarget>
    <RootNamespace>Community.PowerToys.Run.Plugin.TruthPulse</RootNamespace>
    <AssemblyName>Community.PowerToys.Run.Plugin.TruthPulse</AssemblyName>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
  </PropertyGroup>

  <!--
    PowerToys DLL references. Set PowerToysLauncherDir to the directory
    containing Wox.Plugin.dll on your machine. Common locations:
      - %LOCALAPPDATA%\PowerToys                          (MSIX / Store install)
      - C:\Program Files\PowerToys\modules\launcher       (MSI install)
    Override at build time: dotnet build -p:PowerToysLauncherDir=C:\path\to\dir
  -->
  <PropertyGroup>
    <PowerToysLauncherDir Condition="'$(PowerToysLauncherDir)' == ''">$(LOCALAPPDATA)\PowerToys</PowerToysLauncherDir>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="Wox.Plugin">
      <HintPath>$(PowerToysLauncherDir)\Wox.Plugin.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Wox.Infrastructure">
      <HintPath>$(PowerToysLauncherDir)\Wox.Infrastructure.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="PowerToys.ManagedCommon">
      <HintPath>$(PowerToysLauncherDir)\PowerToys.ManagedCommon.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <None Update="plugin.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Images\*.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
