<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0-windows10.0.22621.0</TargetFramework>
    <UseWPF>true</UseWPF>
    <Platforms>x64;ARM64</Platforms>
    <PlatformTarget>$(Platform)</PlatformTarget>
    <RootNamespace>Community.PowerToys.Run.Plugin.TruthPulse</RootNamespace>
    <AssemblyName>Community.PowerToys.Run.Plugin.TruthPulse</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="PowerToys.Common.UI" Version="0.89.0" />
    <PackageReference Include="PowerToys.ManagedCommon" Version="0.89.0" />
    <PackageReference Include="PowerToys.Settings.UI.Lib" Version="0.89.0" />
    <PackageReference Include="Wox.Plugin" Version="0.89.0" />
  </ItemGroup>

  <ItemGroup>
    <None Update="plugin.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Images\*.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
